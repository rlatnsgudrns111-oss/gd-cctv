# go2rtc/go2rtc.service - systemd 서비스 파일

[Unit]
Description=go2rtc RTSP 릴레이 스트리밍 서버
After=network.target

[Service]
Type=simple
User=go2rtc
Group=go2rtc
ExecStart=/usr/local/bin/go2rtc -config /etc/go2rtc/go2rtc.yaml
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
